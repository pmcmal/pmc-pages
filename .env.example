# Skopiuj ten plik do .env.local i wypełnij prawdziwymi wartościami.
# .env.local nie jest commitowany do gita.

# Supabase (wymagane dla generatorów AI: PowerShell, Przepisy, Opowiadania,
# Elektronika, Filozof/Coach — każdy z nich wywołuje Supabase Edge Function).
# Znajdziesz je w Supabase Dashboard -> Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenWeatherMap (opcjonalne — bez tego strona Inteligentna Pogoda
# używa symulowanych danych pogodowych).
# Darmowy klucz: https://home.openweathermap.org/api_keys
VITE_OPENWEATHERMAP_API_KEY=
